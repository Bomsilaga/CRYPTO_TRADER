# Bybit API credentials (required for live trading)
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret

# Set to 'true' to use Bybit testnet
BYBIT_TESTNET=false

# Set to 'live' to enable real order execution (default: paper mode)
TRADING_MODE=paper

# Web Push VAPID keys — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=your@email.com

# Cron job secret (used to protect the /api/cron/scan endpoint)
CRON_SECRET=your_cron_secret
